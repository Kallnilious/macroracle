# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed.

# PostgreSQL connection string for the dev database.
# In the sandbox this is set automatically by entrypoint.sh.
DATABASE_URL=postgresql://node@localhost:5432/macroracle_dev

# PostgreSQL connection string for the test database (used by integration tests).
TEST_DATABASE_URL=postgresql://node@localhost:5432/macroracle_test

# API server port (optional, defaults to 3001)
PORT=3001

# USDA FoodData Central API key (free, get at https://fdc.nal.usda.gov/api-guide.html)
USDA_API_KEY=DEMO_KEY
